---
import BaseLayout from './BaseLayout.astro';
import AuthorCard from '../components/AuthorCard.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import TagPill from '../components/TagPill.astro';

interface AuthorObject {
  name: string;
  role?: string;
  bio?: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  image?: string;
  readTime?: number;
  author: string | AuthorObject;
  tags?: string[];
  slug: string;
}

const { title, description, pubDate, category, image, readTime = 5, author, tags = [], slug } = Astro.props;

const authorObj: AuthorObject =
  typeof author === 'string'
    ? { name: author, role: '', bio: '' }
    : author;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <div style="padding-top:80px;">
    <article style="max-width:780px;margin:0 auto;padding:3rem 1.5rem 4rem;">

      <!-- Breadcrumb / Meta -->
      <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.5rem;flex-wrap:wrap;">
        <span class="category-badge">{category}</span>
        <span style="color:#444;font-size:0.7rem;">/</span>
        <span style="font-family:'Inter',sans-serif;font-size:0.7rem;color:#888888;letter-spacing:0.08em;text-transform:uppercase;">
          {formattedDate}
        </span>
        <span style="color:#444;font-size:0.7rem;">/</span>
        <span style="font-family:'Inter',sans-serif;font-size:0.7rem;color:#888888;letter-spacing:0.08em;text-transform:uppercase;">
          {readTime} MIN READ
        </span>
      </div>

      <!-- Headline -->
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2.25rem,5vw,3.5rem);color:#ffffff;text-transform:uppercase;letter-spacing:0.02em;line-height:1.05;margin-bottom:1.5rem;">
        {title}
      </h1>

      <!-- Lede / Subtitle as styled blockquote -->
      <blockquote style="border-left:3px solid #CCFF00;padding-left:1.5rem;font-family:'Playfair Display',serif;font-style:italic;color:#888888;font-size:1.125rem;line-height:1.7;margin:0 0 2rem;">
        {description}
      </blockquote>

      <!-- Author + Share row -->
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;margin-bottom:1.5rem;">
        <AuthorCard name={authorObj.name} role={authorObj.role} compact={true} />

        <button
          onclick="navigator.clipboard.writeText(window.location.href).then(() => alert('Link copied!'))"
          style="display:inline-flex;align-items:center;gap:0.5rem;border:1px solid #ffffff;background:none;color:#ffffff;font-family:'Inter',sans-serif;font-size:0.7rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;padding:0.5rem 1rem;cursor:pointer;transition:background 0.2s,color 0.2s;"
          onmouseover="this.style.background='#ffffff';this.style.color='#0a0a0a'"
          onmouseout="this.style.background='none';this.style.color='#ffffff'"
        >
          <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
          </svg>
          SHARE ARTICLE
        </button>
      </div>

      <!-- Separator -->
      <div style="border-top:1px solid #2a2a2a;margin-bottom:2.5rem;"></div>

      <!-- Article content -->
      <div class="article-content">
        <slot />
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div style="display:flex;flex-wrap:wrap;gap:0.5rem;margin-top:2.5rem;padding-top:2rem;border-top:1px solid #2a2a2a;">
          {tags.map((tag) => (
            <TagPill tag={tag} />
          ))}
        </div>
      )}

      <!-- Author bio card -->
      {authorObj.bio && (
        <div style="margin-top:2.5rem;">
          <AuthorCard name={authorObj.name} role={authorObj.role} bio={authorObj.bio} />
        </div>
      )}

      <!-- Related posts -->
      <RelatedPosts currentSlug={slug} category={category} />

    </article>
  </div>
</BaseLayout>
