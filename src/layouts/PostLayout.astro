---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  image?: string;
  author: string;
  tags?: string[];
}

const { title, description, pubDate, category, image, author, tags = [] } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  DevOps: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  SRE: 'bg-cyan-500/20 text-cyan-400 border-cyan-500/30',
  Kubernetes: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  Cloud: 'bg-sky-500/20 text-sky-400 border-sky-500/30',
  Linux: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
  Automação: 'bg-green-500/20 text-green-400 border-green-500/30',
};

const categoryColor = categoryColors[category] ?? 'bg-slate-500/20 text-slate-400 border-slate-500/30';
---

<BaseLayout title={title} description={description} image={image}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <!-- Back link -->
    <a href="/blog" class="inline-flex items-center gap-2 text-slate-400 hover:text-accent-cyan transition-colors mb-8 group">
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Voltar ao Blog
    </a>

    <!-- Header -->
    <header class="mb-10">
      <span class={`inline-block text-xs font-semibold uppercase tracking-widest px-3 py-1 rounded-full border mb-4 ${categoryColor}`}>
        {category}
      </span>
      <h1 class="text-3xl md:text-5xl font-black text-white leading-tight mb-4">{title}</h1>
      <p class="text-lg text-slate-300 mb-6">{description}</p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-slate-400">
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>
          {author}
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {formattedDate}
        </span>
      </div>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs px-2 py-1 bg-slate-800 text-slate-400 rounded-md border border-slate-700">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Cover image -->
    {image && (
      <div class="rounded-xl overflow-hidden mb-10 border border-slate-700/50">
        <img src={image} alt={title} class="w-full h-64 md:h-96 object-cover" />
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none
      prose-headings:font-bold prose-headings:text-white
      prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl
      prose-p:text-slate-300 prose-p:leading-relaxed
      prose-a:text-accent-cyan prose-a:no-underline hover:prose-a:underline
      prose-strong:text-white
      prose-code:text-accent-cyan prose-code:bg-slate-800 prose-code:px-1 prose-code:rounded
      prose-pre:bg-slate-800/80 prose-pre:border prose-pre:border-slate-700
      prose-table:text-sm prose-th:text-white prose-td:text-slate-300
      prose-blockquote:border-l-accent-blue prose-blockquote:text-slate-300
      prose-li:text-slate-300
    ">
      <slot />
    </div>
  </article>
</BaseLayout>
