---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Sobre" description="Sobre o DevOps & SRE Blog">
  <div class="pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-12 text-center">
        <div class="w-20 h-20 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-xl shadow-blue-500/30">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Sobre o Blog</h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Um espaço dedicado a conteúdo técnico de qualidade sobre tecnologia moderna
        </p>
      </div>

      <!-- Content -->
      <div class="space-y-8">
        <div class="bg-[#1a2744] rounded-2xl border border-slate-700/50 p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Sobre o Projeto</h2>
          <p class="text-slate-300 leading-relaxed mb-4">
            O <strong class="text-white">DevOps & SRE Blog</strong> é um projeto criado para compartilhar conhecimento técnico sobre as melhores práticas em DevOps, Site Reliability Engineering, Cloud Computing, Kubernetes e automação de infraestrutura.
          </p>
          <p class="text-slate-300 leading-relaxed">
            Todo o conteúdo é produzido em português, com foco em profissionais e entusiastas de tecnologia que buscam aprofundar seus conhecimentos e evoluir na carreira.
          </p>
        </div>

        <div class="bg-[#1a2744] rounded-2xl border border-slate-700/50 p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Tópicos Abordados</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              { icon: '⚙️', title: 'DevOps', desc: 'Cultura, CI/CD, automação e colaboração' },
              { icon: '📊', title: 'SRE', desc: 'Confiabilidade, SLO/SLI e Error Budget' },
              { icon: '☁️', title: 'Cloud', desc: 'AWS, GCP, Azure e arquitetura cloud-native' },
              { icon: '🚀', title: 'Kubernetes', desc: 'Orquestração de containers e ecossistema CNCF' },
              { icon: '🐧', title: 'Linux', desc: 'Administração, shell scripting e performance' },
              { icon: '🤖', title: 'Automação', desc: 'Terraform, Ansible e IaC' },
            ].map(({ icon, title, desc }) => (
              <div class="flex items-start gap-3 p-4 bg-slate-800/40 rounded-xl border border-slate-700/30">
                <span class="text-2xl">{icon}</span>
                <div>
                  <p class="text-white font-semibold">{title}</p>
                  <p class="text-slate-400 text-sm">{desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-[#1a2744] rounded-2xl border border-slate-700/50 p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Stack Utilizada</h2>
          <div class="flex flex-wrap gap-3">
            {['Astro', 'TailwindCSS', 'TypeScript', 'Markdown', 'Google Fonts (Raleway)'].map((tech) => (
              <span class="px-4 py-2 bg-blue-500/10 border border-blue-500/20 text-blue-400 rounded-lg text-sm font-medium">
                {tech}
              </span>
            ))}
          </div>
        </div>

        <div class="text-center pt-4">
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-7 py-3.5 bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 text-white font-semibold rounded-xl transition-all duration-300 shadow-lg shadow-blue-500/30"
          >
            Ver todos os posts
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
