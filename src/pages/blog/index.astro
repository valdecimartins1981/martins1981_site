---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Articles" description="All articles on Technology, DevOps and SRE">
  <div style="padding-top:80px;">
    <div style="max-width:1280px;margin:0 auto;padding:3rem 1.5rem;">

      <!-- Header -->
      <div style="border-bottom:1px solid #2a2a2a;padding-bottom:2rem;margin-bottom:2.5rem;">
        <h1 style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(2.5rem,6vw,5rem);color:#ffffff;text-transform:uppercase;letter-spacing:0.02em;line-height:1;margin-bottom:0.75rem;">
          ARTICLES
        </h1>
        <p style="font-family:'Playfair Display',serif;font-style:italic;color:#888888;font-size:1rem;">
          Technical writing on DevOps, SRE, Platform Engineering, and Incidents
        </p>
      </div>

      <!-- Articles list -->
      <div style="max-width:860px;">
        {sortedPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.slug}
            readTime={post.data.readTime}
          />
        ))}

        {sortedPosts.length === 0 && (
          <p style="font-family:'Playfair Display',serif;font-style:italic;color:#888888;padding:3rem 0;">
            No articles published yet.
          </p>
        )}
      </div>

    </div>
  </div>
</BaseLayout>
