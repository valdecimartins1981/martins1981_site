---
const navLinks = [
  { href: '/blog', label: 'ARTICLES' },
  { href: '/sre', label: 'SRE' },
  { href: '/devops', label: 'DEVOPS' },
  { href: '/platform', label: 'PLATFORM' },
  { href: '/incidents', label: 'INCIDENTS' },
  { href: '/about', label: 'ABOUT' },
];

const pathname = Astro.url.pathname;
---

<header style="position:fixed;top:0;left:0;right:0;z-index:50;background:#0a0a0a;border-bottom:1px solid #2a2a2a;">
  <div style="max-width:1280px;margin:0 auto;padding:0 1.5rem;">
    <div style="display:flex;align-items:center;justify-content:space-between;height:64px;">

      <!-- Logo -->
      <a href="/" style="text-decoration:none;display:flex;flex-direction:column;line-height:1.1;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#CCFF00;letter-spacing:0.02em;text-transform:uppercase;">
          martins1981
        </span>
        <span style="font-family:'Inter',sans-serif;font-size:0.6rem;color:#888888;letter-spacing:0.15em;text-transform:uppercase;font-weight:500;">
          FOR ENGINEERS RUNNING PROD
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="desktop-nav" style="display:flex;align-items:center;gap:0.25rem;">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            style={`font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:0.4rem 0.75rem;text-decoration:none;transition:color 0.2s;color:${pathname === href || pathname.startsWith(href + '/') ? '#CCFF00' : '#ffffff'};`}
            onmouseover="this.style.color='#CCFF00'"
            onmouseout={`this.style.color='${pathname === href || pathname.startsWith(href + '/') ? '#CCFF00' : '#ffffff'}'`}
          >
            {label}
          </a>
        ))}
        <a
          href="#newsletter"
          style="font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:0.4rem 0.75rem;text-decoration:none;color:#CCFF00;transition:opacity 0.2s;"
          onmouseover="this.style.opacity='0.7'"
          onmouseout="this.style.opacity='1'"
        >
          NEWSLETTER
        </a>
        <!-- Search icon -->
        <button
          aria-label="Search"
          style="background:none;border:none;cursor:pointer;padding:0.4rem;color:#888888;display:flex;align-items:center;"
          onmouseover="this.style.color='#ffffff'"
          onmouseout="this.style.color='#888888'"
        >
          <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8" stroke-width="2"/>
            <path d="m21 21-4.35-4.35" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </nav>

      <!-- Hamburger (mobile) -->
      <button
        id="menu-btn"
        class="hamburger-btn"
        style="display:none;background:none;border:none;cursor:pointer;padding:0.4rem;color:#ffffff;"
        aria-label="Menu"
      >
        <svg id="icon-open" width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:none;">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" style="display:none;border-top:1px solid #2a2a2a;background:#0a0a0a;">
    <div style="padding:1rem 1.5rem;display:flex;flex-direction:column;gap:0.25rem;">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          style={`font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:0.6rem 0;text-decoration:none;color:${pathname === href ? '#CCFF00' : '#ffffff'};border-bottom:1px solid #1a1a1a;`}
        >
          {label}
        </a>
      ))}
      <a
        href="#newsletter"
        style="font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:0.6rem 0;text-decoration:none;color:#CCFF00;"
      >
        NEWSLETTER
      </a>
    </div>
  </div>
</header>

<style>
  @media (max-width: 768px) {
    .desktop-nav {
      display: none !important;
    }
    .hamburger-btn {
      display: flex !important;
    }
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.style.display === 'none';
    if (menu) menu.style.display = isHidden ? 'block' : 'none';
    if (iconOpen) iconOpen.style.display = isHidden ? 'none' : 'block';
    if (iconClose) iconClose.style.display = isHidden ? 'block' : 'none';
  });
</script>
