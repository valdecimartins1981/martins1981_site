---
interface Props {
  name: string;
  role?: string;
  bio?: string;
  compact?: boolean;
}

const { name, role = '', bio = '', compact = false } = Astro.props;
const initial = name.charAt(0).toUpperCase();
---

{compact ? (
  <div style="display:flex;align-items:center;gap:0.75rem;">
    <div style="width:36px;height:36px;background:#CCFF00;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1rem;color:#0a0a0a;">
        {initial}
      </span>
    </div>
    <div>
      <p style="font-family:'Inter',sans-serif;font-weight:600;font-size:0.875rem;color:#ffffff;margin:0;">{name}</p>
      {role && (
        <p style="font-family:'Inter',sans-serif;font-size:0.75rem;color:#CCFF00;margin:0;letter-spacing:0.05em;">{role}</p>
      )}
    </div>
  </div>
) : (
  <div style="background:#111111;border:1px solid #2a2a2a;padding:1.5rem;display:flex;gap:1.25rem;align-items:flex-start;">
    <div style="width:52px;height:52px;background:#CCFF00;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:1.5rem;color:#0a0a0a;">
        {initial}
      </span>
    </div>
    <div style="flex:1;">
      <p style="font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:1.1rem;color:#ffffff;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">{name}</p>
      {role && (
        <p style="font-family:'Inter',sans-serif;font-size:0.75rem;color:#CCFF00;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 0.75rem;">{role}</p>
      )}
      {bio && (
        <p style="font-family:'Playfair Display',serif;font-style:italic;color:#888888;font-size:0.9rem;line-height:1.6;margin:0;">{bio}</p>
      )}
    </div>
  </div>
)}
