---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  slug: string;
  image?: string;
}

const { title, description, pubDate, category, slug, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('pt-BR', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const categoryColors: Record<string, string> = {
  DevOps: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  SRE: 'bg-cyan-500/20 text-cyan-400 border-cyan-500/30',
  Kubernetes: 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  Cloud: 'bg-sky-500/20 text-sky-400 border-sky-500/30',
  Linux: 'bg-orange-500/20 text-orange-400 border-orange-500/30',
  Automação: 'bg-green-500/20 text-green-400 border-green-500/30',
};

const categoryColor = categoryColors[category] ?? 'bg-slate-500/20 text-slate-400 border-slate-500/30';
---

<article class="group bg-[#1a2744] rounded-xl border border-slate-700/50 overflow-hidden hover:border-blue-500/40 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-blue-500/10 flex flex-col">
  {image && (
    <div class="h-48 overflow-hidden bg-slate-800">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  {!image && (
    <div class="h-48 bg-gradient-to-br from-blue-900/40 to-cyan-900/20 flex items-center justify-center">
      <svg class="w-16 h-16 text-blue-500/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>
  )}

  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center justify-between mb-3">
      <span class={`text-xs font-semibold uppercase tracking-widest px-2.5 py-1 rounded-full border ${categoryColor}`}>
        {category}
      </span>
      <time class="text-xs text-slate-500">{formattedDate}</time>
    </div>

    <h3 class="text-white font-bold text-lg leading-snug mb-3 group-hover:text-blue-400 transition-colors line-clamp-2">
      {title}
    </h3>

    <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 flex-1 mb-4">
      {description}
    </p>

    <a
      href={`/blog/${slug}`}
      class="inline-flex items-center gap-1.5 text-blue-400 hover:text-cyan-400 text-sm font-medium transition-colors group/link mt-auto"
    >
      Ler mais
      <svg class="w-4 h-4 group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
