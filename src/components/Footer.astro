---
const categories = [
  { href: '/sre', label: 'SRE' },
  { href: '/devops', label: 'DevOps' },
  { href: '/platform', label: 'Platform' },
  { href: '/blog?category=observability', label: 'Observability' },
  { href: '/incidents', label: 'Incidents & Postmortems' },
  { href: '/blog?category=culture', label: 'Engineering Culture' },
];

const colophon = [
  { href: '/about', label: 'About the Publication' },
  { href: '#newsletter', label: 'The Weekly Pager' },
  { href: '/blog', label: 'Search the Archive' },
  { href: '/rss.xml', label: 'RSS Feed' },
];
---

<footer id="newsletter" style="background:#0a0a0a;border-top:1px solid #2a2a2a;margin-top:4rem;">
  <div style="max-width:1280px;margin:0 auto;padding:4rem 1.5rem 2rem;">

    <!-- Big logo -->
    <div style="margin-bottom:2rem;">
      <a href="/" style="text-decoration:none;">
        <span style="font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(3rem,8vw,6rem);color:#CCFF00;letter-spacing:0.02em;text-transform:uppercase;line-height:1;">
          martins1981
        </span>
      </a>
    </div>

    <!-- Description -->
    <p style="font-family:'Playfair Display',serif;font-style:italic;color:#888888;font-size:1rem;max-width:520px;line-height:1.7;margin-bottom:3rem;">
      A bold publication for SREs, DevOps engineers, and platform teams. Written by people who have been paged at 3am.
    </p>

    <!-- Columns -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2.5rem;margin-bottom:3rem;">
      <!-- Categories -->
      <div>
        <h3 style="font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#ffffff;margin-bottom:1rem;">
          CATEGORIES
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem;">
          {categories.map(({ href, label }) => (
            <li>
              <a
                href={href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#888888;text-decoration:none;transition:color 0.2s;"
                onmouseover="this.style.color='#CCFF00'"
                onmouseout="this.style.color='#888888'"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Colophon -->
      <div>
        <h3 style="font-family:'Inter',sans-serif;font-size:0.72rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:#ffffff;margin-bottom:1rem;">
          COLOPHON
        </h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.6rem;">
          {colophon.map(({ href, label }) => (
            <li>
              <a
                href={href}
                style="font-family:'Inter',sans-serif;font-size:0.875rem;color:#888888;text-decoration:none;transition:color 0.2s;"
                onmouseover="this.style.color='#ffffff'"
                onmouseout="this.style.color='#888888'"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid #2a2a2a;padding-top:1.5rem;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:0.75rem;">
      <p style="font-family:'Inter',sans-serif;font-size:0.78rem;color:#555555;">
        © {new Date().getFullYear()} martins1981. All rights reserved.
      </p>
      <p style="font-family:'Inter',sans-serif;font-size:0.78rem;color:#555555;">
        Built for the terminal generation.
      </p>
    </div>
  </div>
</footer>
