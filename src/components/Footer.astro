---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/devops', label: 'DevOps' },
  { href: '/sre', label: 'SRE' },
  { href: '/sobre', label: 'Sobre' },
];

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/valdecimartins1981',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/valdecimartins',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: 'Twitter',
    href: 'https://twitter.com/valdecimartins',
    icon: `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.336-8.39L2.25 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
];
---

<footer class="bg-[#080f1f] border-t border-slate-800/60 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-3">
          <div class="w-9 h-9 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <span class="block text-white font-bold text-sm">DevOps & SRE</span>
            <span class="block text-slate-400 text-xs">Blog</span>
          </div>
        </a>
        <p class="text-slate-400 text-sm leading-relaxed">
          Conteúdo técnico sobre DevOps, SRE, Cloud e automação para profissionais e entusiastas de tecnologia.
        </p>
        <!-- Social links -->
        <div class="flex gap-3 pt-1">
          {socialLinks.map(({ label, href, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="w-9 h-9 flex items-center justify-center text-slate-400 hover:text-white bg-slate-800 hover:bg-blue-600 rounded-lg transition-all duration-200"
              set:html={icon}
            />
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Navegação</h3>
        <ul class="space-y-2">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-slate-400 hover:text-white text-sm transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Topics -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-widest mb-4">Tópicos</h3>
        <ul class="space-y-2">
          {['DevOps', 'SRE', 'Kubernetes', 'Cloud', 'Linux', 'Automação'].map((topic) => (
            <li>
              <a href={`/blog`} class="text-slate-400 hover:text-cyan-400 text-sm transition-colors">
                {topic}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-8 border-t border-slate-800/60 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p>© {new Date().getFullYear()} DevOps & SRE Blog. Todos os direitos reservados.</p>
      <p>Feito com ❤️ e <a href="https://astro.build" target="_blank" rel="noopener" class="text-slate-400 hover:text-white transition-colors">Astro</a></p>
    </div>
  </div>
</footer>
